{
  "name": "telegram-member-mover-api",
  "version": "2.0.0",
  "description": "Server API untuk memindahkan member grup Telegram menggunakan username",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "setup": "node src/setup.js",
    "list-groups": "node scripts/get-group-id.js",
    "docker:build": "docker build -t telegram-member-mover .",
    "docker:run": "docker run -p 3000:3000 --env-file .env telegram-member-mover",
    "docker:stop": "docker stop $(docker ps -q --filter ancestor=telegram-member-mover)"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "gramjs": "^2.13.0",
    "winston": "^3.11.0",
    "express-rate-limit": "^6.10.0",
    "helmet": "^7.0.0",
    "compression": "^1.7.4"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
